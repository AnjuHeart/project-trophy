// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// ENUMS
// ---------------------------------------------------------

enum Role {
  ADMIN
  SEMI_ADMIN
  SUPPORTER
  USER
}

// ---------------------------------------------------------
// USERS & PROFILES
// ---------------------------------------------------------

model User {
  id             String   @id @default(cuid())
  usernameSlug   String   @unique // NON-EDITABLE
  username       String   @unique // EDITABLE
  email          String   @unique
  password       String   // Encoded password
  role           Role     @default(USER)
  
  profile        UserProfile?
  guides         Guide[]          @relation("UserGuides")
  guidesTemp     GuideTemp[]      @relation("UserGuidesTemp")
  progress       PlayerProgress[]
  userTitles     UserTitle[]
  userBadges     UserBadge[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  statistics     UserStatistic?
}

model UserProfile {
  id               String  @id @default(cuid())
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Aesthetics
  profilePhotoUrl  String?
  profileBannerUrl String?
  displayName      String?
  pronouns         String?
  customStatus     String?
  location         String?
  
  // Displayed Title & Badge (Selected from unlocked)
  profileTitleId   String?
  profileBadgeId   String?
  
  // External Profiles
  steamProfileUrl    String?
  xboxProfileUrl     String?
  psnProfileUrl      String?
  nintendoProfileUrl String?
  
  // Socials
  xId         String?
  blueskyId   String?
  discordId   String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ---------------------------------------------------------
// UNLOCKS: TITLES & BADGES
// ---------------------------------------------------------

model UserTitle {
  id               String          @id @default(cuid())
  userId           String
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  hallOfFameTitleId String
  hallOfFameTitle  HallOfFameTitle @relation(fields: [hallOfFameTitleId], references: [id], onDelete: Cascade)
  
  unlockedAt       DateTime        @default(now())

  @@unique([userId, hallOfFameTitleId])
}

model HallOfFameTitle {
  id               String          @id @default(cuid())
  title            String          // e.g., "Thief of Hearts"
  
  hallOfFameGameId String
  hallOfFameGame   HallOfFameGame  @relation(fields: [hallOfFameGameId], references: [id], onDelete: Cascade)
  
  awardedTo        UserTitle[]
}

model UserBadge {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileBadgeId String
  profileBadge   ProfileBadge @relation(fields: [profileBadgeId], references: [id], onDelete: Cascade)
  
  unlockedAt     DateTime     @default(now())

  @@unique([userId, profileBadgeId])
}

model ProfileBadge {
  id              String      @id @default(cuid())
  slug            String      @unique // e.g., "number-farmer", "impeccable-discipline"
  name            String      @unique // e.g., "Number Farmer", "Impeccable Discipline"
  requirementText String      // e.g., "Complete 20 games with average completion under 10 hours."
  flavorText      String      // e.g., "This user only cares about making their numbers go up."

  iconUrl         String      // Path to the custom badge art asset
  tailwindClasses String      @default("border-slate-800 bg-slate-900/50 text-slate-300")

  isSecret        Boolean     @default(false)
  
  unlockedBy      UserBadge[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ---------------------------------------------------------
// CORE GAME DATA
// ---------------------------------------------------------

model Game {
  id                      String   @id @default(cuid())
  slug                    String   @unique
  title                   String

  thumbnailUrl            String
  backgroundUrl           String
  logoUrl                 String

  genres                  String[]
  isHomogeneous           Boolean  @default(false)

  totalAchievements       Int
  blindPlaythroughHours   Int
  minimumPlaythroughs     Int      @default(1)
  timeTo100PercentPerfect Int
  timeTo100PercentBase    Int

  categoryContextDescription String
  difficultyRating           Int     @default(1)
  completionOverview         String

  mainCategoryId String
  mainCategory   MainCategory @relation(fields: [mainCategoryId], references: [slug])

  secondaryCategories SecondaryCategory[]
  achievements        Achievement[]
  hallOfFameInductions HallOfFameGame[]
  guides              Guide[]
  guidesTemp          GuideTemp[]
  playerProgress      PlayerProgress[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MainCategory {
  id            String   @id @default(cuid())
  slug          String   @unique
  label         String   @unique
  emoji         String
  bgGradient    String
  hoverGradient String
  
  games         Game[]
  guides        Guide[]       // Submitted by guides
  guidesTemp    GuideTemp[]   

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SecondaryCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  label       String   @unique
  description String
  
  games       Game[]
  guides      Guide[]       // Submitted by guides
  guidesTemp  GuideTemp[]   

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AchievementCategory {
  id                String               @id @default(cuid())
  slug              String               @unique
  label             String               @unique
  description       String
  weight            Int                  @default(0)
  theme             String               @default("")
  tailwindClasses   String?

  achievements      Achievement[]
  guideAchievements GuideAchievement[]   // Many-to-many override per guide

  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
}

model Achievement {
  id                    String              @id @default(cuid())
  slug                  String
  name                  String
  description           String
  notes                 String?
  imageUrl              String?
  isSecret              Boolean             @default(false)

  gameId                String
  game                  Game                @relation(fields: [gameId], references: [id], onDelete: Cascade)

  // Base categorization (Fallback/Official)
  achievementCategoryId String
  achievementCategory   AchievementCategory @relation(fields: [achievementCategoryId], references: [id])

  // Guide-specific categorizations
  guideOverrides        GuideAchievement[]
  guideSteps            GuideStep[]         // Achievements expected in a specific step
  guideStepsTemp        GuideStepTemp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------------------------------------------------------
// HALL OF FAME
// ---------------------------------------------------------

model HallOfFameCategory {
  id            String           @id @default(uuid())
  slug          String           @unique
  number        Int              @unique
  name          String           @unique
  description   String
  communityIcons Json

  inductedGames  HallOfFameGame[]

  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model HallOfFameGame {
  id         String @id @default(uuid())
  reason     String
  
  gameId     String
  game       Game   @relation(fields: [gameId], references: [slug], onDelete: Cascade)
  
  categoryId String
  category   HallOfFameCategory @relation(fields: [categoryId], references: [slug], onDelete: Cascade)

  titles     HallOfFameTitle[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([gameId, categoryId])
}

// ---------------------------------------------------------
// GUIDES (PUBLISHED)
// ---------------------------------------------------------

model Guide {
  id                 String             @id @default(cuid())
  slug               String             @unique
  gameId             String
  game               Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  authorId           String
  author             User               @relation("UserGuides", fields: [authorId], references: [id], onDelete: Cascade)
  
  approvedAt         DateTime?
  upvotes            Int                @default(0)
  views              Int                @default(0)
  difficultySubmitted Int
  stepsAmount        Int                @default(0)

  // Submitted Categories
  mainCategoryId     String
  mainCategory       MainCategory       @relation(fields: [mainCategoryId], references: [id])
  secondaryCategories SecondaryCategory[]

  steps              GuideStep[]
  guideAchievements  GuideAchievement[]
  playerProgress     PlayerProgress[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GuideStep {
  id             String        @id @default(cuid())
  guideId        String
  guide          Guide         @relation(fields: [guideId], references: [id], onDelete: Cascade)
  
  stepNumber     Int
  stepWeight     String        // e.g., "h1", "h2", "h3"
  title          String?
  description    String?       @db.Text // Allows for larger rich-text storage
  estimatedTime  String?       // e.g., "15 minutes"

  // Expected achievements in this step
  achievements   Achievement[] 
}

model GuideAchievement {
  id               String               @id @default(cuid())
  guideId          String
  guide            Guide                @relation(fields: [guideId], references: [id], onDelete: Cascade)
  
  achievementId    String
  achievement      Achievement          @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  
  notes            String?              @db.Text
  
  // Custom categories assigned by the guide author
  categories       AchievementCategory[] 

  @@unique([guideId, achievementId])
}

// ---------------------------------------------------------
// GUIDES (TEMP / WORK-IN-PROGRESS)
// ---------------------------------------------------------

model GuideTemp {
  id                 String             @id @default(cuid())
  gameId             String
  game               Game               @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  authorId           String
  author             User               @relation("UserGuidesTemp", fields: [authorId], references: [id], onDelete: Cascade)
  
  difficultySubmitted Int?

  // Submitted Categories
  mainCategoryId     String?
  mainCategory       MainCategory?      @relation(fields: [mainCategoryId], references: [id])
  secondaryCategories SecondaryCategory[]

  stepsTemp          GuideStepTemp[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model GuideStepTemp {
  id             String        @id @default(cuid())
  guideTempId    String
  guideTemp      GuideTemp     @relation(fields: [guideTempId], references: [id], onDelete: Cascade)
  
  stepNumber     Int
  stepWeight     String        
  title          String?
  description    String?       @db.Text
  estimatedTime  String?

  achievements   Achievement[] 
}

// ---------------------------------------------------------
// PLAYER PROGRESS
// ---------------------------------------------------------

model PlayerProgress {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  gameId         String
  game           Game      @relation(fields: [gameId], references: [id], onDelete: Cascade)
  
  guideId        String
  guide          Guide     @relation(fields: [guideId], references: [id], onDelete: Cascade)
  
  // Bookmark tracking
  currentStepNum Int       @default(1)

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([userId, gameId]) // A user can only track progress on a specific game once at a time
}

// ---------------------------------------------------------
// USER STATISTICS & TRACKING ENGINE
// ---------------------------------------------------------

model UserStatistic {
  id                                       String   @id @default(cuid())
  userId                                   String   @unique
  user                                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // -------------------------------------------------------
  // General Totals
  // -------------------------------------------------------
  totalGamesCompleted                      Int      @default(0)
  totalAchievementsObtained                Int      @default(0)
  numberOfSeriesBeaten                     Int      @default(0)

  // -------------------------------------------------------
  // Hour Trackers (Stackable)
  // -------------------------------------------------------
  gamesWithAverageCompletionLowerThan5Hrs  Int      @default(0)
  gamesWithAverageCompletionLowerThan10Hrs Int      @default(0)
  gamesWithAverageCompletionHigherThan30Hrs Int     @default(0)
  gamesWithAverageCompletionHigherThan50Hrs Int     @default(0)
  gamesWithAverageCompletionHigherThan100Hrs Int    @default(0)

  // -------------------------------------------------------
  // Playthrough Trackers (Non-stackable)
  // -------------------------------------------------------
  gamesWith1Playthrough                    Int      @default(0)
  gamesWith2Playthrough                    Int      @default(0)
  gamesWith5PlusPlaythroughs               Int      @default(0)

  // -------------------------------------------------------
  // Difficulty Trackers (Non-stackable)
  // -------------------------------------------------------
  difficulty1Games                         Int      @default(0)
  difficulty2Games                         Int      @default(0)
  difficulty3Games                         Int      @default(0)
  difficulty4Games                         Int      @default(0)
  difficulty5Games                         Int      @default(0)
  difficulty6Games                         Int      @default(0)
  difficulty7Games                         Int      @default(0)
  difficulty8Games                         Int      @default(0)
  difficulty9Games                         Int      @default(0)
  difficulty10Games                        Int      @default(0)

  // -------------------------------------------------------
  // Category Trackers
  // -------------------------------------------------------
  deadBrokenCompletionGames                Int      @default(0)
  pieceOfCakeGames                         Int      @default(0)
  allStoryRelatedGames                     Int      @default(0)
  casualFriendlyGames                      Int      @default(0)
  farmingFocusedGames                      Int      @default(0)
  mapSweeperGames                          Int      @default(0)
  highlyCheesableGames                     Int      @default(0)
  willTestYourPatienceGames                Int      @default(0)
  knowledgeHeavyGames                      Int      @default(0)
  deadEndOdysseyGames                      Int      @default(0)
  needsSkilledExecutionGames               Int      @default(0)
  pureMasochismGames                       Int      @default(0)
  extremeDisciplineTestGames               Int      @default(0)
  repetitiveLoopMasteryGames               Int      @default(0)
  cooperativeJourneyGames                  Int      @default(0)
  massiveTimeSinkGames                     Int      @default(0)

  // -------------------------------------------------------
  // Hall Of Fame Trackers
  // -------------------------------------------------------
  hallOfFameGames                          Int      @default(0) // Sum of the below
  famouslyDifficultGames                   Int      @default(0)
  perfectStructureGames                    Int      @default(0)
  forChallengersOnlyGames                  Int      @default(0)
  monumentalEffortGames                    Int      @default(0)
  hiddenGemsGames                          Int      @default(0)
  narrativeDedicationGames                 Int      @default(0)

  // -------------------------------------------------------
  // Community Tropes & Habit Trackers
  // -------------------------------------------------------
  shamelessStatGames                       Int      @default(0)
  dlcHeavyweightGames                      Int      @default(0) // Games with 50+ DLC achievements
  weekendGames                             Int      @default(0) // Games finished on a weekend

  // -------------------------------------------------------
  // Milestone Booleans & Easter Eggs
  // -------------------------------------------------------
  hasCompletedMinecraft                    Boolean  @default(false)
  hasCompletedMyNameIsMayo                 Boolean  @default(false)
  hasBeatenDoomCrossing                    Boolean  @default(false) // Doom Eternal + Animal Crossing
  nightOwlCompletion                       Boolean  @default(false) // Triggered once for a late-night log
  maxedOutMultitasking                     Boolean  @default(false) // Hit the 10-simultaneous-guide limit

  createdAt                                DateTime @default(now())
  updatedAt                                DateTime @updatedAt
}